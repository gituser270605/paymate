<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.pay.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_paymentListFragment"
            app:destination="@id/paymentListFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/paymentListFragment"
        android:name="com.example.pay.PaymentListFragment"
        android:label="Payments"
        tools:layout="@layout/fragment_payment_list">
        <action
            android:id="@+id/action_paymentListFragment_to_addPaymentFragment"
            app:destination="@id/addPaymentFragment" />
    </fragment>

    <fragment
        android:id="@+id/addPaymentFragment"
        android:name="com.example.pay.AddPaymentFragment"
        android:label="Add Payment"
        tools:layout="@layout/fragment_add_payment">
        <argument
            android:name="paymentId"
            app:argType="long"
            android:defaultValue="-1L" />
    </fragment>
</navigation>